{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Universal AI Skill Metadata",
  "type": "object",
  "required": ["id", "name", "version", "category", "description", "entry"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "category": { "type": "string" },
    "description": { "type": "string" },
    "entry": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "adapters": { "type": "array", "items": { "type": "string" } }
  }
}
